<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Whatsapp" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
         <item name="colorPrimary">@color/primaria</item>
        <item name="android:navigationBarColor">@color/primaria</item>
        <item name="bottomAppBarStyle">@style/BottomAppBarStyle</item>


        <item name="android:statusBarColor">@color/primaria</item>
        <item name="android:actionOverflowButtonStyle">
            @style/ActionOverFlowButton
        </item>

    </style>

    <style name="ActionOverFlowButton" parent="Widget.AppCompat.ActionButton.Overflow">
        <item name="android:tint">@color/white</item>
    </style>

    <style name="Ciruclo">
        <item name="cornerSize">50%</item>
    </style>


    <style name="BottomAppBarStyle" parent="Widget.MaterialComponents.BottomAppBar">
        <item name="backgroundTint">@color/primaria</item>
    </style>

    <style name="Theme.Whatsapp" parent="Base.Theme.Whatsapp" />
</resources>